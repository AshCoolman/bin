#!/usr/bin/env bash
set -euo pipefail

BASE_MODEL="${BASE_MODEL:-gemma3:4b}"
MODEL_PREFIX="${MODEL_PREFIX:-gemma3:4b}"
MODEL_DIR="${MODEL_DIR:-$HOME/local-models}"
OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"

usage() {
  cat >&2 <<'EOF'
Usage:
  agent-wiki [16K|32K] [claude|py] [-- extra args...]

Examples:
  agent-wiki 16K py
  agent-wiki 32K py ./notes/example.md
  agent-wiki 16K claude --continue

Env:
  BASE_MODEL=gemma3:4b
  MODEL_PREFIX=gemma3:4b
  MODEL_DIR=~/local-models
  OLLAMA_HOST=http://localhost:11434

Notes:
  - Creates Ollama model variants:
      gemma3:4b-16k
      gemma3:4b-32k
  - "claude" assumes you already have a Claude/Ollama-compatible shim.
  - "py" uses a tiny local Python chat/file-assessment loop against Ollama.
EOF
}

die() {
  echo "FAIL: $*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

choose_context() {
  case "${1:-}" in
    16K|16k|16) echo "16384" ;;
    32K|32k|32) echo "32768" ;;
    *) die "context must be one of: 16K, 32K" ;;
  esac
}

choose_agent() {
  case "${1:-}" in
    claude|py) echo "$1" ;;
    *) die "agent must be one of: claude, py" ;;
  esac
}

ollama_model_exists() {
  local model="$1"
  ollama list | awk 'NR > 1 {print $1}' | grep -Fxq "$model"
}

ensure_ollama_running() {
  if ! curl -fsS "$OLLAMA_HOST/api/tags" >/dev/null 2>&1; then
    echo "Starting Ollama..."
    ollama serve >/tmp/ollama-serve.log 2>&1 &
    for _ in $(seq 1 30); do
      curl -fsS "$OLLAMA_HOST/api/tags" >/dev/null 2>&1 && return 0
      sleep 1
    done
    die "Ollama did not become reachable at $OLLAMA_HOST"
  fi
}

ensure_base_model() {
  if ! ollama_model_exists "$BASE_MODEL"; then
    echo "Pulling base model: $BASE_MODEL"
    ollama pull "$BASE_MODEL"
  fi
}

ensure_context_model() {
  local ctx="$1"
  local model="$2"
  local modelfile="$MODEL_DIR/$model.Modelfile"

  if ollama_model_exists "$model"; then
    echo "PASS: model exists: $model"
    return 0
  fi

  mkdir -p "$MODEL_DIR"

  cat > "$modelfile" <<EOF
FROM $BASE_MODEL
PARAMETER num_ctx $ctx
EOF

  echo "Creating model: $model"
  ollama create "$model" -f "$modelfile"

  ollama_model_exists "$model" || die "model creation failed: $model"
  echo "PASS: created model: $model"
}

launch_py_agent() {
  local model="$1"
  shift || true

  MODEL="$model" OLLAMA_HOST="$OLLAMA_HOST" python3 - "$@" <<'PY'
import json
import os
import sys
import urllib.request

model = os.environ["MODEL"]
host = os.environ.get("OLLAMA_HOST", "http://localhost:11434").rstrip("/")
paths = sys.argv[1:]

system = """You are helping maintain a personal Markdown wiki.

Rules:
- Preserve facts.
- Do not invent missing detail.
- Keep links and code blocks intact.
- Prefer concise, structured Markdown.
- Mark uncertain inferences as "Unclear:".
- Output Markdown only unless asked otherwise.
"""

def ollama_chat(messages):
    req = urllib.request.Request(
        f"{host}/api/chat",
        data=json.dumps({
            "model": model,
            "messages": messages,
            "stream": True,
        }).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    with urllib.request.urlopen(req) as res:
        for line in res:
            if not line.strip():
                continue
            payload = json.loads(line)
            content = payload.get("message", {}).get("content", "")
            if content:
                print(content, end="", flush=True)
            if payload.get("done"):
                print()

def read_markdown_files(paths):
    chunks = []
    for path in paths:
        if not os.path.isfile(path):
            raise SystemExit(f"FAIL: not a file: {path}")
        with open(path, "r", encoding="utf-8") as f:
            chunks.append(f"# File: {path}\n\n{f.read()}")
    return "\n\n---\n\n".join(chunks)

if paths:
    content = read_markdown_files(paths)
    user = f"""Assess these Markdown file(s) for a personal wiki.

Return:
1. Summary
2. Missing context
3. Suggested title
4. Suggested tags
5. Cleaner rewritten draft

Do not invent facts.

{content}
"""
    ollama_chat([
        {"role": "system", "content": system},
        {"role": "user", "content": user},
    ])
else:
    print(f"Using {model}. Paste prompts. Ctrl-D to exit.\n", file=sys.stderr)
    buf = sys.stdin.read().strip()
    if not buf:
        raise SystemExit(0)

    ollama_chat([
        {"role": "system", "content": system},
        {"role": "user", "content": buf},
    ])
PY
}

launch_claude_agent() {
  local model="$1"
  shift || true

  command -v claude >/dev/null 2>&1 || die "missing claude command"

  export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-$OLLAMA_HOST}"
  export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-local-no-auth}"
  export OTEL_TRACES_EXPORTER="${OTEL_TRACES_EXPORTER:-none}"

  echo "Launching claude with model: $model"
  echo "Using ANTHROPIC_BASE_URL=$ANTHROPIC_BASE_URL"

  claude --model "$model" "$@"
}

main() {
  case "${1:-}" in
    ""|-h|--help) usage; exit 0 ;;
  esac

  need ollama
  need curl
  need awk
  need grep

  local ctx agent suffix model
  ctx="$(choose_context "${1:-}")"
  agent="$(choose_agent "${2:-}")"
  shift 2 || true

  suffix="$((ctx / 1024))k"
  model="$MODEL_PREFIX-$suffix"

  ensure_ollama_running
  ensure_base_model
  ensure_context_model "$ctx" "$model"

  case "$agent" in
    py)
      need python3
      launch_py_agent "$model" "$@"
      ;;
    claude)
      launch_claude_agent "$model" "$@"
      ;;
  esac
}

main "$@"
