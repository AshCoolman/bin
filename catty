#!/usr/bin/env bash
set -euo pipefail
CATSEYE="$(cd "$(dirname "$(realpath "$0")")/catseye" && pwd)"

# Install if node_modules missing or package-lock.json is newer than node_modules
if [[ ! -x "$CATSEYE/node_modules/.bin/tsx" ]] || \
   [[ "$CATSEYE/package-lock.json" -nt "$CATSEYE/node_modules" ]]; then
  echo "catty: installing dependencies..." >&2
  npm install --prefix "$CATSEYE" --silent
fi

exec "$CATSEYE/node_modules/.bin/tsx" "$CATSEYE/packages/cli/src/index.ts" "$@"
