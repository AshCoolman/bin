#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: run catlens-lib checks when catlens-lib files are staged.
# Install: git config core.hooksPath hooks

staged=$(git diff --cached --name-only --diff-filter=ACMR)

if ! echo "$staged" | grep -q '^catlens-lib/'; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)/catlens-lib"

echo "pre-commit: catlens-lib/ changes detected"

echo "  → typecheck"
npm run typecheck --silent

echo "  → test"
npm test --silent

echo "pre-commit: ok"
