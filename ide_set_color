#!/usr/bin/env node

// IDE color setter for VSCode, iTerm2, and Zed
// Usage:
//   ide_set_color RRGGBB [--recursive|-r]     apply a color (bare hex — zsh eats #)
//   ide_set_color '#RRGGBB'                   same, with # (must be quoted in zsh)
//   ide_set_color                             interactive picker

const fs = require('fs');
const path = require('path');
const readline = require('readline');
const { execSync } = require('child_process');

const args = process.argv.slice(2);
const RECURSIVE = args.includes('--recursive') || args.includes('-r');
const PERSIST = args.includes('--persist');

function printHelp() {
  console.log('Usage:');
  console.log('  ide_set_color RRGGBB [--recursive|-r] [--persist]   apply a color (bare hex)');
  console.log("  ide_set_color '#RRGGBB'                             same, with # (quote it — zsh treats # as a comment)");
  console.log('  ide_set_color                                       interactive picker');
  console.log('');
  console.log('Targets:');
  console.log('  - package.json "color" in cwd (and nested with -r)');
  console.log('  - .vscode/settings.json workbench background colors');
  console.log('  - iTerm2 current session (OSC 1337 escape)');
  console.log('  - Zed experimental.theme_overrides in ./.zed/settings.json (per-folder)');
  console.log('  - ide_color.json in cwd, if it exists (or always with --persist)');
}

if (args.includes('--help') || args.includes('-h')) {
  printHelp();
  process.exit(0);
}

function findPackageJsonDirs(dir) {
  const out = [];
  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    if (entry.name === 'node_modules' || entry.name.startsWith('.')) continue;
    const full = path.join(dir, entry.name);
    if (entry.isDirectory()) {
      if (fs.existsSync(path.join(full, 'package.json'))) out.push(full);
      try { out.push(...findPackageJsonDirs(full)); } catch (_) {}
    }
  }
  return out;
}

function setPkgColor(repoDir, hex) {
  const p = path.join(repoDir, 'package.json');
  if (!fs.existsSync(p)) return;
  try {
    const pkg = JSON.parse(fs.readFileSync(p, 'utf8'));
    pkg.color = hex;
    fs.writeFileSync(p, JSON.stringify(pkg, null, 2) + '\n');
  } catch (_) {}
}

function setVSCode(repoDir, hex) {
  const vs = path.join(repoDir, '.vscode');
  const sp = path.join(vs, 'settings.json');

  try { if (!fs.existsSync(vs)) fs.mkdirSync(vs); } catch (_) {}

  let current = {};
  try { current = JSON.parse(fs.readFileSync(sp, 'utf8')); } catch (_) {}

  const wcc = current['workbench.colorCustomizations'] || {};
  wcc['activityBar.background'] = hex;
  wcc['titleBar.activeBackground'] = hex;
  wcc['editor.background'] = hex;
  wcc['sideBar.background'] = hex;
  wcc['panel.background'] = hex;
  current['workbench.colorCustomizations'] = wcc;

  try { fs.writeFileSync(sp, JSON.stringify(current, null, 2) + '\n'); } catch (_) {}
}

function setIterm2(hex) {
  // iTerm2 OSC 1337: sets bg of the current session when stdout is that terminal.
  try { process.stdout.write(`\x1b]1337;SetColors=bg=${hex.slice(1)}\x07`); } catch (_) {}
}

function findMatchingBrace(text, openIdx) {
  let depth = 0;
  let inStr = false;
  for (let i = openIdx; i < text.length; i++) {
    const c = text[i];
    if (inStr) {
      if (c === '\\') { i++; continue; }
      if (c === '"') inStr = false;
    } else if (c === '"') inStr = true;
    else if (c === '{') depth++;
    else if (c === '}') { depth--; if (depth === 0) return i; }
  }
  return -1;
}

function writeZedSettingsFile(p, hex) {
  let text = '{}';
  try { if (fs.existsSync(p)) text = fs.readFileSync(p, 'utf8'); } catch (_) {}

  const overrideObj =
`{
    "background": "${hex}",
    "editor.background": "${hex}",
    "editor.gutter.background": "${hex}",
    "terminal.background": "${hex}",
    "panel.background": "${hex}",
    "tab_bar.background": "${hex}",
    "title_bar.background": "${hex}",
    "status_bar.background": "${hex}"
  }`;

  const keyMatch = text.match(/"(?:experimental\.)?theme_overrides"\s*:/);
  if (keyMatch) {
    const openIdx = text.indexOf('{', keyMatch.index + keyMatch[0].length);
    if (openIdx === -1) return;
    const closeIdx = findMatchingBrace(text, openIdx);
    if (closeIdx === -1) return;
    text = text.slice(0, openIdx) + overrideObj + text.slice(closeIdx + 1);
  } else {
    const rootOpen = text.indexOf('{');
    if (rootOpen === -1) {
      text = `{\n  "experimental.theme_overrides": ${overrideObj}\n}\n`;
    } else {
      text = text.slice(0, rootOpen + 1)
        + `\n  "experimental.theme_overrides": ${overrideObj},`
        + text.slice(rootOpen + 1);
    }
  }

  try { fs.writeFileSync(p, text); } catch (_) {}
}

function setZed(repoDir, hex) {
  const dotZed = path.join(repoDir, '.zed');
  try { if (!fs.existsSync(dotZed)) fs.mkdirSync(dotZed); } catch (_) {}
  writeZedSettingsFile(path.join(dotZed, 'settings.json'), hex);
}

function setIdeColorJson(repoDir, hex) {
  const p = path.join(repoDir, 'ide_color.json');
  if (!PERSIST && !fs.existsSync(p)) return;
  try { fs.writeFileSync(p, JSON.stringify({ color: hex }, null, 2) + '\n'); } catch (_) {}
}

function applyAll(hex) {
  const root = process.cwd();
  setPkgColor(root, hex);
  const dirs = RECURSIVE ? findPackageJsonDirs(root) : [];
  for (const d of dirs) setPkgColor(d, hex);
  for (const d of [root, ...dirs]) setVSCode(d, hex);
  for (const d of [root, ...dirs]) setZed(d, hex);
  setIdeColorJson(root, hex);
  setIterm2(hex);
  console.log(`Applied ${hex} to ${1 + dirs.length} package(s), VSCode, iTerm2, and Zed`);
}

// ---------- color math ----------

function hslToHex(h, s, l) {
  h = ((h % 360) + 360) % 360;
  s = Math.max(0, Math.min(1, s));
  l = Math.max(0, Math.min(1, l));
  const c = (1 - Math.abs(2 * l - 1)) * s;
  const hp = h / 60;
  const x = c * (1 - Math.abs((hp % 2) - 1));
  let r = 0, g = 0, b = 0;
  if (hp < 1) [r, g, b] = [c, x, 0];
  else if (hp < 2) [r, g, b] = [x, c, 0];
  else if (hp < 3) [r, g, b] = [0, c, x];
  else if (hp < 4) [r, g, b] = [0, x, c];
  else if (hp < 5) [r, g, b] = [x, 0, c];
  else [r, g, b] = [c, 0, x];
  const m = l - c / 2;
  const toHex = v => Math.round((v + m) * 255).toString(16).padStart(2, '0');
  return '#' + toHex(r) + toHex(g) + toHex(b);
}

function hexToHsl(hex) {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  const l = (max + min) / 2;
  let h = 0, s = 0;
  if (max !== min) {
    const d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    if (max === r) h = (g - b) / d + (g < b ? 6 : 0);
    else if (max === g) h = (b - r) / d + 2;
    else h = (r - g) / d + 4;
    h *= 60;
  }
  return { h, s, l };
}

// 10 dark colors spread around the hue ring with varied saturation/lightness
function generatePalette() {
  const out = [];
  for (let i = 0; i < 10; i++) {
    const hue = (i * 36 + Math.random() * 18 - 9) % 360;
    const sat = 0.40 + Math.random() * 0.25;   // 0.40 – 0.65
    const light = 0.16 + Math.random() * 0.10; // 0.16 – 0.26
    out.push(hslToHex(hue, sat, light));
  }
  return out;
}

// 10 variants close to the given color — fine-grained exploration
function generateNeighbors(hex) {
  const { h, s, l } = hexToHsl(hex);
  const out = [hex];
  const deltas = [
    [-20, 0, 0], [20, 0, 0],
    [0, -0.12, 0], [0, 0.12, 0],
    [0, 0, -0.03], [0, 0, 0.03],
    [-10, 0, 0.02], [10, 0, -0.02],
    [-8, 0.08, 0],
  ];
  for (const [dh, ds, dl] of deltas) {
    out.push(hslToHex(h + dh, s + ds, l + dl));
  }
  return out;
}

function swatch(hex) {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  const lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
  const fg = lum < 128 ? '\x1b[38;2;255;255;255m' : '\x1b[38;2;0;0;0m';
  const bg = `\x1b[48;2;${r};${g};${b}m`;
  return `${bg}${fg}  ${hex}  \x1b[0m`;
}

function copyToClipboard(text) {
  try {
    execSync('pbcopy', { input: text });
    return true;
  } catch (_) { return false; }
}

async function pickerLoop() {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const ask = q => new Promise(res => rl.question(q, res));

  let palette = generatePalette();
  let mode = 'palette';

  while (true) {
    console.log('');
    console.log(`  (${mode})`);
    palette.forEach((hex, i) => {
      console.log(`  ${String(i + 1).padStart(2)}  ${swatch(hex)}`);
    });
    console.log('');
    const ans = (await ask('  [1-10] select, [r] regenerate, [q] quit: ')).trim().toLowerCase();
    if (ans === 'q' || ans === '') { rl.close(); return; }
    if (ans === 'r') { palette = generatePalette(); mode = 'palette'; continue; }
    const n = parseInt(ans, 10);
    if (!(n >= 1 && n <= 10)) continue;
    const selected = palette[n - 1];

    const action = (await ask(`  ${swatch(selected)}  [a] apply, [c] copy, [n] narrow, [b] back: `)).trim().toLowerCase();
    if (action === 'q') { rl.close(); return; }
    if (action === 'b' || action === '') continue;
    if (action === 'a') { rl.close(); applyAll(selected); return; }
    if (action === 'c') {
      const ok = copyToClipboard(selected);
      console.log(ok ? `  copied ${selected}` : `  ${selected}  (pbcopy unavailable)`);
      rl.close();
      return;
    }
    if (action === 'n') { palette = generateNeighbors(selected); mode = `near ${selected}`; continue; }
  }
}

// ---------- entry ----------

const raw = args.find(a => /^#?[0-9A-Fa-f]{6}$/.test(a));
if (raw) {
  const HEX = raw.startsWith('#') ? raw : '#' + raw;
  applyAll(HEX);
} else {
  pickerLoop();
}
