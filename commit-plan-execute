#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
commit-plan-execute — interactively run commit commands from a plan file

USAGE
  commit-plan-execute              run latest plan in ./commit-plan/
  commit-plan-execute --help       this message

PLAN FORMAT (for AI agents — token-efficient)
  Path:      ./commit-plan/<YYYY-MM-DD-HHmm-ss>.md
  Content:   one commit per line, each line a single shell command:
             git add <files> && git cm -m "<conventional commit msg>"
  Parser:    grep -nE 'git add .* && git cm', then exclude any line containing
             the literal token *DONE*. Leading list markers (- or *) and
             surrounding backticks are stripped. Each line is split on
             ` && git cm ` so stage runs first, then commit.
  Anything else in the file is ignored — no headers, prose, or rationale needed.

DONE MARKER
  After a commit succeeds — or after its stage step is a no-op because the
  change is already in the tree — the runner appends ` *DONE*` to that line
  in the plan file. Re-running the same plan therefore only retries
  unfinished commits.

  To re-run a line that's already marked, delete the *DONE* token from it.
  Do not put a literal *DONE* inside a commit message: the parser would
  treat the line as already done and skip it.

MINIMAL EXAMPLE
  git add src/foo.ts && git cm -m "fix(foo): handle null id" *DONE*
  git add src/bar.ts test/bar.test.ts && git cm -m "feat(bar): add retry"

RULES
  - one line = one commit; no multi-line commands
  - quote the message with double quotes
  - list every file explicitly; no globs unless you mean them
  - order matters: lines run top-to-bottom

RUNTIME
  for each unfinished line:
    1. stage runs automatically
    2. staged files are listed (the result, not the command)
    3. prompt: (c)ommit, (e)dit message, (d)iff, (s)kip
    4. on commit success or empty-stage skip, the line is marked *DONE*
EOF
  exit 0
fi

latest=$(ls -t ./commit-plan/*.md 2>/dev/null | head -n1 || true)
if [[ -z "${latest:-}" ]]; then
  echo "no commit plan found in ./commit-plan/" >&2
  exit 1
fi

out=./tmp/commit-plan
mkdir -p "$out"
rm -f "$out"/*.stage "$out"/*.msg "$out"/*.sh "$out"/*.lineno

mark_done() {
  local lineno="$1"
  local current
  current=$(sed -n "${lineno}p" "$latest" 2>/dev/null || echo "")
  if [[ "$current" == *"*DONE*"* ]]; then
    return 0
  fi
  if ! sed -i '' "${lineno}s/\$/ *DONE*/" "$latest" 2>/dev/null; then
    echo "warning: failed to append *DONE* to line $lineno of $latest" >&2
  fi
}

total=$(grep -cE 'git add .* && git cm' "$latest" 2>/dev/null || true)
total="${total:-0}"

i=0
while IFS= read -r entry; do
  lineno="${entry%%:*}"
  raw="${entry#*:}"
  cleaned=$(printf '%s' "$raw" | sed -E 's/^[[:space:]]*([-*][[:space:]]+)?//; s/^`//; s/`[[:space:]]*$//')
  i=$((i + 1))
  printf -v base '%02d' "$i"
  stage_part="${cleaned%% && git cm *}"
  commit_part="git cm ${cleaned#* && git cm }"
  printf '%s\n' "$stage_part" > "$out/$base.stage"
  printf '%s\n' "$commit_part" > "$out/$base.msg"
  printf '%s\n' "$lineno"     > "$out/$base.lineno"
done < <(
  grep -nE 'git add .* && git cm' "$latest" | grep -v '\*DONE\*' || true
)

if [[ "$i" -eq 0 ]]; then
  if [[ "$total" -gt 0 ]]; then
    echo "all $total commit(s) in $latest already marked *DONE*"
    exit 0
  fi
  echo "no commit commands found in $latest" >&2
  exit 1
fi

echo "wrote $i unfinished commit(s) to $out/ (from $latest, $total total)"
echo

for stage_file in "$out"/*.stage; do
  base="${stage_file%.stage}"
  msg_file="$base.msg"
  lineno_file="$base.lineno"
  lineno=$(cat "$lineno_file" 2>/dev/null || echo "")
  label=$(basename "$base")

  echo "── $label ──"
  echo "\$ $(cat "$stage_file")"
  if ! bash "$stage_file"; then
    echo "stage failed — opening editor on stage command" >&2
    ${EDITOR:-zed -w} "$stage_file"
    echo "\$ $(cat "$stage_file")"
    if ! bash "$stage_file"; then
      echo "stage still failing, skipping" >&2
      echo
      continue
    fi
  fi

  if [[ -z "$(git diff --cached --name-status)" ]]; then
    echo "nothing staged — already committed or no-op, marking done"
    [[ -n "$lineno" ]] && mark_done "$lineno"
    echo
    continue
  fi

  while :; do
    echo
    echo "staged:"
    git diff --cached --name-status | sed 's/^/  /'
    echo
    echo "message: $(cat "$msg_file")"
    echo
    read -r -p '(c)ommit, (e)dit message, (d)iff, (s)kip? ' choice </dev/tty
    case "$choice" in
      c)
        if bash "$msg_file"; then
          [[ -n "$lineno" ]] && mark_done "$lineno"
          echo
          break
        else
          rc=$?
          echo "commit failed (exit $rc) — opening editor on message" >&2
          ${EDITOR:-zed -w} "$msg_file"
        fi
        ;;
      e) ${EDITOR:-zed -w} "$msg_file" ;;
      d) git --no-pager diff --cached | ${PAGER:-less -R} ;;
      s)
        echo "unstaging and skipping (line not marked done)"
        git reset --quiet
        break
        ;;
      *) echo "type c, e, d, or s" ;;
    esac
  done
done

echo "done. split files remain at $out/"
