#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve symlinks so compress_video_dir → compress_video still finds the lib.
if [[ -L "${BASH_SOURCE[0]}" ]]; then
  _real="$(readlink "${BASH_SOURCE[0]}")"
  case "$_real" in
    /*) SCRIPT_DIR="$(cd "$(dirname "$_real")" && pwd)";;
    *)  SCRIPT_DIR="$(cd "$SCRIPT_DIR" && cd "$(dirname "$_real")" && pwd)";;
  esac
fi
# shellcheck source=./compress_video_lib.sh
source "$SCRIPT_DIR/compress_video_lib.sh"

# --- tunable defaults -----------------------------------------------------
# Tweak these to change encode behavior. The ffmpeg command is built from
# these values; no magic numbers hide downstream.
AUDIO_KBPS=64              # mono AAC bitrate
HEADROOM=0.88              # safety factor for mb/pct modes to stay under cap
SCALE_FACTOR=0.75          # output resolution multiplier
TARGET_FPS=30              # framerate cap (skipped by --match)
UNSHARP_PARAMS="5:5:1.0:5:5:0.0"
MIN_VIDEO_KBPS=50          # floor for video bitrate in mb/pct modes
X264_PARAMS="bframes=0:nal-hrd=cbr"
X264_PRESET="slow"
GOP_SIZE=30
PIX_FMT="yuv420p"
DEFAULT_SPEED="1.5"

# --- usage ----------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage:
  compress_video <path> <target> [options]
  compress_video help

Description:
  Compress a video file — or a whole directory of videos — with a
  single-pass, VBV-locked x264 encode. One script handles both files
  and directories; the invocation name is irrelevant, so the symlink
  compress_video_dir works the same way.

Target (required, suffix matters):
  10mb       Absolute target file size in megabytes
  10%        Target as percent of source file size
  15br       Target video bitrate in Mbps (rough scale: 2=low, 15=high)

Options:
  --speed N     Playback speed multiplier (default 1.5). Audio is
                pitch-corrected via a chained atempo filter.
  --match       Preserve the original framerate (skip the fps=30 cap).
                Use for slow-motion footage where dropping frames
                would be wrong.
  --dry-run     Print the ffmpeg command that would run, then exit.
                Useful for previewing a batch or debugging a change.
  -h, --help    Show this help.

Examples:
  compress_video demo.mov 10mb                        # 10 MB target
  compress_video demo.mov 10%                         # 10% of source
  compress_video demo.mov 15br                        # 15 Mbps
  compress_video ./videos 10% --speed 1.25            # batch, interactive
  compress_video slowmo.mov 20mb --match --speed 1    # preserve framerate
  compress_video demo.mov 10mb --dry-run              # preview only

Notes:
  - Output is MP4, H.264, mono AAC (64 kbps), scaled to 75%, fps 30
    (unless --match), with an unsharp pass. Output name encodes all
    parameters so re-runs are self-describing and idempotent.
  - mb/pct modes apply an 88% headroom factor to stay under the cap.
    br mode encodes at the exact bitrate and lets file size fall out
    of duration.
  - When <path> is a directory, already-compressed outputs are
    detected by filename and excluded from the menu by default.
EOF
}

# --- arg state (set by parse_args) ----------------------------------------
ARG_PATH=""
ARG_TARGET=""
ARG_SPEED="$DEFAULT_SPEED"
ARG_MATCH=0
ARG_DRY_RUN=0

parse_args() {
  local -a positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help|help)
        usage; exit 0;;
      --dry-run)
        ARG_DRY_RUN=1; shift;;
      --match)
        ARG_MATCH=1; shift;;
      --speed)
        [[ $# -ge 2 ]] || _cvlib_err "--speed requires a value"
        ARG_SPEED="$2"; shift 2;;
      --)
        shift
        while [[ $# -gt 0 ]]; do positional+=("$1"); shift; done;;
      -*)
        _cvlib_err "Unknown option: $1";;
      *)
        positional+=("$1"); shift;;
    esac
  done

  if [[ ${#positional[@]} -lt 2 ]]; then
    usage >&2
    _cvlib_err "path and target required"
  fi
  if [[ ${#positional[@]} -gt 2 ]]; then
    _cvlib_err "unexpected extra argument: ${positional[2]}"
  fi

  ARG_PATH="${positional[0]}"
  ARG_TARGET="${positional[1]}"
  _cvlib_require_positive "$ARG_SPEED" "speed"
}

# --- dependency + capability checks ---------------------------------------
check_deps() {
  _cvlib_need ffmpeg
  _cvlib_need ffprobe
  _cvlib_need bc
  _cvlib_need awk
  _cvlib_need sed
}

check_ff_capabilities() {
  _cvlib_ff_has encoders libx264 || _cvlib_err "ffmpeg built without libx264 encoder"
  _cvlib_ff_has encoders aac     || _cvlib_err "ffmpeg built without AAC encoder"
  _cvlib_ff_has filters  setpts  || _cvlib_err "ffmpeg missing 'setpts' filter"
  _cvlib_ff_has filters  fps     || _cvlib_err "ffmpeg missing 'fps' filter"
  _cvlib_ff_has filters  scale   || _cvlib_err "ffmpeg missing 'scale' filter"
  _cvlib_ff_has filters  unsharp || _cvlib_err "ffmpeg missing 'unsharp' filter"
  _cvlib_ff_has filters  atempo  || _cvlib_err "ffmpeg missing 'atempo' filter"
}

# --- small formatting helpers ---------------------------------------------
fmt_duration() {
  local secs
  secs=$(printf '%.0f' "$1")
  printf '%d:%02d:%02d' $((secs/3600)) $(((secs%3600)/60)) $((secs%60))
}

fmt_percent() {
  # $1 is a 0..1 fraction; echoes e.g. "75"
  echo "$1 * 100" | bc -l | awk '{printf "%.0f",$0}'
}

# --- pre-run summary ------------------------------------------------------
print_summary() {
  local input="$1" output="$2" mode="$3" target_value="$4"
  local video_kbps="$5" audio_kbps="$6" speed="$7" match="$8"
  local duration="$9"

  local size_mb in_dur out_dur
  size_mb=$(echo "$(_cvlib_file_size_bytes "$input")/1024/1024" | bc -l | awk '{printf "%.1f",$0}')
  in_dur=$(fmt_duration "$duration")
  out_dur=$(fmt_duration "$(echo "$duration / $speed" | bc -l)")

  local mode_line
  case "$mode" in
    mb)  mode_line="mb  (target ${target_value} MB, headroom $(fmt_percent "$HEADROOM")%)";;
    pct) mode_line="pct (${target_value}% of source, headroom $(fmt_percent "$HEADROOM")%)";;
    br)  mode_line="br  (${target_value} Mbps)";;
  esac

  local match_line="no"
  [[ "$match" -eq 1 ]] && match_line="yes"

  local fps_display="$TARGET_FPS"
  [[ "$match" -eq 1 ]] && fps_display="(match)"

  printf '\n'
  printf 'compress_video:\n'
  printf '  input    : %s  (%s MB, %s)\n' "$(basename "$input")" "$size_mb" "$in_dur"
  printf '  output   : %s\n' "$(basename "$output")"
  printf '  mode     : %s\n' "$mode_line"
  printf '  bitrate  : video %s kbps, audio %s kbps (mono)\n' "$video_kbps" "$audio_kbps"
  printf '  speed    : %sx   (output duration %s)\n' "$speed" "$out_dur"
  printf '  video    : scale %s%%, fps %s, unsharp on\n' "$(fmt_percent "$SCALE_FACTOR")" "$fps_display"
  printf '  match fps: %s\n' "$match_line"
  printf '\n'
}

# --- per-file encode ------------------------------------------------------
encode_file() {
  local input="$1" target_spec="$2"

  [[ -f "$input" ]] || _cvlib_err "Input not found: $input"

  local parsed mode target_value
  parsed="$(_cvlib_parse_target "$target_spec")"
  mode="${parsed%% *}"
  target_value="${parsed##* }"

  # Probe duration
  local duration
  duration=$(ffprobe -v error -show_entries format=duration \
                     -of default=noprint_wrappers=1:nokey=1 "$input") || true
  [[ -n "${duration:-}" ]] || _cvlib_err "Could not probe duration: $input"

  # Per-mode: compute bitrate + choose output name
  local video_kbps buf_kbps output max_mb
  case "$mode" in
    mb)
      max_mb="$target_value"
      read -r video_kbps buf_kbps < <(_cvlib_compute_bitrate_for_size \
        "$duration" "$ARG_SPEED" "$max_mb" "$AUDIO_KBPS" "$HEADROOM" "$MIN_VIDEO_KBPS")
      output="$(_cvlib_output_name_size "$input" "$max_mb" "$ARG_SPEED" "$ARG_MATCH")"
      ;;
    pct)
      local src_bytes src_mb
      src_bytes="$(_cvlib_file_size_bytes "$input")"
      src_mb=$(echo "$src_bytes/1024/1024" | bc -l | awk '{printf "%.3f",$0}')
      max_mb=$(echo "$src_mb * $target_value / 100" | bc -l | awk '{printf "%.3f",$0}')
      read -r video_kbps buf_kbps < <(_cvlib_compute_bitrate_for_size \
        "$duration" "$ARG_SPEED" "$max_mb" "$AUDIO_KBPS" "$HEADROOM" "$MIN_VIDEO_KBPS")
      output="$(_cvlib_output_name_size "$input" "$max_mb" "$ARG_SPEED" "$ARG_MATCH")"
      ;;
    br)
      read -r video_kbps buf_kbps < <(_cvlib_compute_bitrate_for_br "$target_value")
      output="$(_cvlib_output_name_bitrate "$input" "$target_value" "$ARG_SPEED" "$ARG_MATCH")"
      ;;
  esac

  # Filters + sync args
  local vf af sync_args
  vf="$(_cvlib_build_video_filter "$ARG_SPEED" "$ARG_MATCH" \
        "$SCALE_FACTOR" "$TARGET_FPS" "$UNSHARP_PARAMS")"
  af="$(_cvlib_build_audio_filter "$ARG_SPEED")"
  sync_args="$(_cvlib_detect_sync_args "$ARG_MATCH")"

  # --- Assemble ffmpeg command.
  # Argument order is preserved from the pre-refactor script so that
  # identical inputs + flags produce byte-identical output. Do not
  # reorder these lines without updating the golden tests.
  local -a cmd
  cmd=(ffmpeg -hide_banner -y -i "$input"
       -map 0:v:0 -map 0:a:0? -sn -dn)
  if [[ -n "$sync_args" ]]; then
    # shellcheck disable=SC2206
    local -a sync_arr=( $sync_args )
    cmd+=("${sync_arr[@]}")
  fi
  cmd+=(-vf "$vf"
        -pix_fmt "$PIX_FMT"
        -c:v libx264 -preset "$X264_PRESET" -g "$GOP_SIZE" -x264-params "$X264_PARAMS"
        -b:v "${video_kbps}k" -minrate "${video_kbps}k"
        -maxrate "${video_kbps}k" -bufsize "${buf_kbps}k")
  if [[ -n "$af" ]]; then
    cmd+=(-filter:a "$af")
  fi
  cmd+=(-c:a aac -ac 1 -b:a "${AUDIO_KBPS}k"
        -movflags +faststart
        "$output")

  print_summary "$input" "$output" "$mode" "$target_value" \
                "$video_kbps" "$AUDIO_KBPS" "$ARG_SPEED" "$ARG_MATCH" "$duration"

  if [[ "$ARG_DRY_RUN" -eq 1 ]]; then
    printf 'DRY RUN — command that would execute:\n'
    local a
    for a in "${cmd[@]}"; do
      printf '  %s\n' "$a"
    done
    printf '\n'
    return 0
  fi

  printf 'Running:'
  printf ' %q' "${cmd[@]}"
  printf '\n'
  "${cmd[@]}"
}

# --- per-dir encode (interactive menu) ------------------------------------
encode_dir() {
  local dir="$1" target_spec="$2"
  [[ -d "$dir" ]] || _cvlib_err "Dir not found: $dir"

  # Validate target early so the user doesn't sit through a menu only
  # to be told their target is bad.
  _cvlib_parse_target "$target_spec" >/dev/null

  shopt -s nullglob
  local -a videos=()
  local f
  for f in "$dir"/*; do
    [[ -f "$f" ]] || continue
    _cvlib_is_video_ext "$f" || continue
    videos+=("$f")
  done
  shopt -u nullglob

  [[ ${#videos[@]} -gt 0 ]] || _cvlib_err "No videos found in $dir"

  # Default selection: everything that isn't already a compressed output.
  local -a selected=()
  for f in "${videos[@]}"; do
    if _cvlib_is_compressed_output "$f"; then
      selected+=("0")
    else
      selected+=("1")
    fi
  done

  # Interactive toggle menu (behavior preserved from compress_video_dir).
  local input i idx mark tok
  while true; do
    echo "Select videos to compress (toggle by number, Enter to continue):"
    for i in "${!videos[@]}"; do
      idx=$((i + 1))
      mark="[ ]"
      [[ "${selected[i]}" -eq 1 ]] && mark="[x]"
      printf ' %2d %s %s\n' "$idx" "$mark" "$(basename "${videos[i]}")"
    done
    echo "Commands: numbers to toggle, 'a' = all, 'n' = none, 'q' = quit"

    read -r -p "> " input || exit 1
    input="${input//,/ }"
    [[ -z "$input" ]] && break
    case "$input" in
      q|quit) exit 0;;
      a|all)
        for i in "${!selected[@]}"; do selected[i]=1; done
        continue;;
      n|none)
        for i in "${!selected[@]}"; do selected[i]=0; done
        continue;;
    esac
    for tok in $input; do
      if [[ "$tok" =~ ^[0-9]+$ ]]; then
        if (( tok >= 1 && tok <= ${#videos[@]} )); then
          i=$((tok - 1))
          if [[ "${selected[i]}" -eq 1 ]]; then selected[i]=0
          else selected[i]=1
          fi
        else
          printf 'Out of range: %s\n' "$tok" >&2
        fi
      else
        printf 'Invalid input: %s\n' "$tok" >&2
      fi
    done
  done

  local -a to_process=()
  for i in "${!videos[@]}"; do
    [[ "${selected[i]}" -eq 1 ]] && to_process+=("${videos[i]}")
  done

  if [[ ${#to_process[@]} -eq 0 ]]; then
    echo "No videos selected; exiting."
    exit 0
  fi

  for f in "${to_process[@]}"; do
    encode_file "$f" "$target_spec"
  done
}

# --- main -----------------------------------------------------------------
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  parse_args "$@"
  check_deps
  check_ff_capabilities

  if [[ -f "$ARG_PATH" ]]; then
    encode_file "$ARG_PATH" "$ARG_TARGET"
  elif [[ -d "$ARG_PATH" ]]; then
    encode_dir "$ARG_PATH" "$ARG_TARGET"
  else
    _cvlib_err "Path not found: $ARG_PATH"
  fi
}

main "$@"
